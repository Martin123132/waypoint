{
  "name": "waypoint",
  "private": true,
  "version": "0.0.0",
  "description": "Self-hosted dynamic QR code and short-link manager.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build && tsc -p tsconfig.server.json",
    "ci:d-drive": "node scripts/with-d-drive-cache.mjs npm ci",
    "dev:d-drive": "node scripts/with-d-drive-cache.mjs npm run dev",
    "release:review:dry-run": "node scripts/generate-release-review-outcome.mjs",
    "release:review:write": "node scripts/generate-release-review-outcome.mjs --write",
    "start": "node dist-server/index.js",
    "lint": "eslint .",
    "verify": "npm run lint && npm run test:storage && npm run test:readiness && npm run test:examples && npm run test:utm && npm test && npm run test:ui",
    "verify:d-drive": "node scripts/with-d-drive-cache.mjs npm run verify",
    "test": "npm run build && npm run test:domain",
    "test:domain": "node tests/domain-routing.test.mjs",
    "test:examples": "node tests/examples.test.mjs",
    "test:readiness": "node tests/public-readiness.test.mjs",
    "test:storage": "node tests/storage-policy.test.mjs",
    "test:utm": "tsx tests/utm.test.ts",
    "test:ui": "node tests/guided-ui.test.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "csv-parse": "^7.0.0",
    "fastify": "^5.8.5",
    "lucide-react": "^1.21.0",
    "nanoid": "^5.1.15",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "yazl": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/yazl": "^3.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright": "^1.61.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
