HOST=127.0.0.1
WAYPOINT_PORT=4040
WAYPOINT_DB=./data/waypoint.sqlite
WAYPOINT_PUBLIC_URL=http://127.0.0.1:4040
WAYPOINT_DOMAIN_PROTOCOL=http
WAYPOINT_COOKIE_SECURE=0

# PORT also works on hosts that inject it and takes precedence over WAYPOINT_PORT.
# Existing OPENQR_* variables still work as fallbacks for older installs:
# OPENQR_PORT, OPENQR_DB, OPENQR_PUBLIC_URL, OPENQR_DOMAIN_PROTOCOL,
# and OPENQR_COOKIE_SECURE.
